            _angular_core__WEBPACK_IMPORTED_MODULE_0__["ɵɵelementEnd"]();
            _angular_core__WEBPACK_IMPORTED_MODULE_0__["ɵɵelementStart"](95, "li");
            _angular_core__WEBPACK_IMPORTED_MODULE_0__["ɵɵelementStart"](96, "b");
            _angular_core__WEBPACK_IMPORTED_MODULE_0__["ɵɵtext"](97, "d.");
            _angular_core__WEBPACK_IMPORTED_MODULE_0__["ɵɵelementEnd"]();
            _angular_core__WEBPACK_IMPORTED_MODULE_0__["ɵɵtext"](98, " The acceptance of these terms will not violate, conflict with, require consent under, or result in any breach or default under (i) any of its organizational documents (including its partnership agreement, its certificate of incorporation and by-laws, as applicable), (ii) any applicable laws or (iii) the provisions of any contract or agreement to which it is a party or to which any of its material assets are bound. ");
